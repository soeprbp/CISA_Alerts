# Optional Slack webhook
SLACK_WEBHOOK_URL=

# Optional Microsoft Teams incoming webhook
TEAMS_WEBHOOK_URL=

# Optional SMTP email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=cisa-alerts@example.com
SMTP_TO=you@example.com

# Use STARTTLS for SMTP
SMTP_STARTTLS=true

# Optional Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
SMS_TO=

# Optional Zoom Phone SMS API
ZOOM_SMS_ACCOUNT_ID=
ZOOM_SMS_CLIENT_ID=
ZOOM_SMS_CLIENT_SECRET=
ZOOM_SMS_ACCESS_TOKEN=
ZOOM_SMS_SENDER_PHONE_NUMBER=
ZOOM_SMS_SENDER_USER_ID=
ZOOM_SMS_TO=

# Optional protection for /api/run and manual dashboard runs
CRON_SECRET=
